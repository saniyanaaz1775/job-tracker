{
  "name": "job-notification-design-tokens",
  "colors": {
    "background": "#F7F6F3",
    "text-primary": "#111111",
    "accent": "#8B0000",
    "success": "#3B7A57",
    "warning": "#C47A00",
    "border-muted": "#E6E4E1",
    "surface": "#FFFFFF"
  },
  "typography": {
    "heading-family": "Georgia, 'Times New Roman', serif",
    "body-family": "Inter, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
    "body-size": "16px",
    "body-line-height": 1.7,
    "scale": {
      "h1": "36px",
      "h2": "28px",
      "h3": "20px",
      "body": "16px"
    },
    "max-text-width": "720px"
  },
  "spacing": {
    "xs": "8px",
    "sm": "16px",
    "md": "24px",
    "lg": "40px",
    "xl": "64px"
  },
  "radius": {
    "base": "8px"
  },
  "motion": {
    "duration-short": "150ms",
    "duration-default": "180ms",
    "timing": "cubic-bezier(.22,.1,.21,1)"
  },
  "borders": {
    "width": "1px",
    "style": "solid"
  }
}

